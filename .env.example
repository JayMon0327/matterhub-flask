# === MatterHub 환경 설정 ===

# --- Home Assistant ---
HA_host="http://localhost:8123"
hass_token=""

# --- MatterHub 식별 ---
matterhub_id=""

# === 벤더 선택 (이것만 바꾸면 기본값 전환) ===
MATTERHUB_VENDOR="konai"

# === MQTT 연결 (미설정 시 벤더 기본값 사용) ===
# MQTT_ENDPOINT=""
# MQTT_CLIENT_ID=""
# MQTT_CERT_PATH=""

# === MQTT 토픽 (미설정 시 벤더 기본값 사용) ===
# MQTT_TOPIC_SUBSCRIBE=""
# MQTT_TOPIC_PUBLISH=""

# === 테스트 토픽 ===
# MQTT_TEST_TOPIC=""
# MQTT_TEST_TOPIC_SUBSCRIBE=""
# MQTT_TEST_TOPIC_PUBLISH=""

# === 센서 보고 (미설정 시 벤더 기본값 사용, 쉼표 구분) ===
# MQTT_REPORT_ENTITY_IDS=""

# === 이벤트 조절 ===
# MQTT_EVENT_THROTTLE_SEC="2"
# MQTT_EVENT_DEDUP_WINDOW_SEC="3"

# === 테스트 구독자 ===
# ENABLE_TEST_SUBSCRIBER="0"

# === 디바이스 상태 커스텀 토픽 발행 ===
# MQTT_DEVICE_STATE_INTERVAL_SEC="60"
# MQTT_DEVICE_STATE_CHUNK_SIZE_KB="100"

# === 디바이스 알림 (device_alerts) ===
# MQTT_ALERT_CHECK_INTERVAL_SEC="30"
# MQTT_ALERT_BATTERY_THRESHOLD="0"

# === MatterHub 토픽 구독 (업데이트 명령 수신) ===
SUBSCRIBE_MATTERHUB_TOPICS="1"

# === 자동 프로비저닝 ===
# MATTERHUB_AUTO_PROVISION="1"
